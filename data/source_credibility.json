  "_comment": "Source credibility tiers for DoomsdayWatch. Higher tier = more weight in signal scoring.",
  "_methodology": "Based on MediaBiasFactCheck factual rating + institutional reliability + signal speed",
  "tiers": {
    "1_official": {
      "weight": 3.0,
      "label": "Official Statement",
      "description": "Direct government/military/IGO statements, press releases, official social media"
    },
    "2_wire": {
      "weight": 2.0,
      "label": "Wire Service",
      "description": "Reuters, AP, AFP — primary news gatherers, fast and verified"
    },
    "3_established": {
      "weight": 1.5,
      "label": "Established Media",
      "description": "Major international outlets with editorial standards"
    },
    "4_regional": {
      "weight": 1.0,
      "label": "Regional/Niche",
      "description": "Regional outlets, specialist publications, lower editorial oversight"
    },
    "5_unverified": {
      "weight": 0.3,
      "label": "Unverified/Social",
      "description": "Social media, blogs, Telegram channels, anonymous sources"
    }
  },
